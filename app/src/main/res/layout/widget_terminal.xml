<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#CC1E1E2E"
    android:padding="12dp"
    android:radius="12dp">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="λ TermX"
        android:textColor="#89B4FA"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Terminal preview -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="$ _"
        android:textColor="#A6E3A1"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:background="#1A1A2E"
        android:padding="6dp"
        android:layout_marginBottom="8dp" />

    <!-- Buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/widget_new_session"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="+ New"
            android:textSize="11sp"
            android:textColor="#CDD6F4"
            android:background="#2A2B3C"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/widget_wake_lock"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="🔒 Wake: OFF"
            android:textSize="11sp"
            android:textColor="#CDD6F4"
            android:background="#2A2B3C"
            android:layout_marginStart="4dp" />

    </LinearLayout>

</LinearLayout>
