<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Toolbar with tabs -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/toolbar_background"
        android:elevation="4dp"
        app:titleTextColor="@color/text_primary"
        app:subtitleTextColor="@color/text_secondary" />

    <!-- Session tab strip -->
    <HorizontalScrollView
        android:id="@+id/tab_scroll"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="@color/toolbar_background"
        android:scrollbars="none">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/tab_recycler"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal" />

    </HorizontalScrollView>

    <!-- Terminal ViewPager (swipe between sessions) -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/session_pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Terminal container (for single session / non-pager mode) -->
    <FrameLayout
        android:id="@+id/terminal_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        android:background="@color/background" />

    <!-- Extra keys bar -->
    <com.termx.app.keyboard.ExtraKeysView
        android:id="@+id/extra_keys"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@color/extra_keys_background"
        android:visibility="visible" />

    <!-- Soft keyboard toggle button -->
    <ImageButton
        android:id="@+id/btn_toggle_keyboard"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:src="@android:drawable/ic_menu_sort_by_size"
        android:background="#1A1A2E"
        android:contentDescription="Toggle keyboard"
        android:scaleType="center" />

</LinearLayout>
